---
import { cn } from "@/lib/utils/cn";

interface Props {
  label: string;
  value: string;
  meta?: string;
  trend?: string;
  positive?: boolean;
  class?: string;
}

const { label, value, meta, trend, positive, class: className } = Astro.props;
---

<article class={cn("rounded-[1.75rem] border border-line/70 bg-surface-alt/70 p-5 transition-transform duration-200 hover:-translate-y-0.5", className)}>
  <p class="text-sm text-muted">{label}</p>
  <div class="mt-3 flex items-end justify-between gap-4">
    <p class="text-2xl font-semibold tracking-tight text-ink md:text-3xl">{value}</p>
    {trend && (
      <span
        class={cn(
          "rounded-full px-2.5 py-1 text-xs font-semibold",
          positive === true && "bg-mint/12 text-mint",
          positive === false && "bg-red-100 text-red-700",
          positive === undefined && "bg-ink/5 text-muted"
        )}
      >
        {trend}
      </span>
    )}
  </div>
  {meta && <p class="mt-3 text-sm text-muted">{meta}</p>}
</article>
