---
import { cn } from "@/lib/utils/cn";

interface Props {
  title: string;
  body: string;
  variant?: "warning" | "error" | "info";
}

const { title, body, variant = "info" } = Astro.props;

const variantClasses = {
  info: "border-sky/30 bg-sky/10 text-ink",
  warning: "border-accent/30 bg-accent/10 text-ink",
  error: "border-red-200 bg-red-50 text-red-900"
};
---

<div class={cn("rounded-2xl border p-4", variantClasses[variant])}>
  <p class="text-sm font-semibold">{title}</p>
  <p class="mt-1 text-sm leading-6 text-muted">{body}</p>
</div>
