---
import { DATA_SOURCES } from "@/lib/constants/sources";
---

<footer class="border-t border-line/70 py-10">
  <div class="mx-auto flex max-w-7xl flex-col gap-4 px-5 md:px-8 lg:px-10">
    <p class="text-sm text-muted">
      BTC-Visualizer is an educational open-source project built with public data. It is designed to explain market, network, and scarcity signals clearly, not to provide trading advice.
    </p>
    <div class="flex flex-wrap gap-3 text-sm text-muted">
      {DATA_SOURCES.map((source) => (
        <a
          href={source.href}
          target="_blank"
          rel="noreferrer"
          class="rounded-full border border-line/70 bg-surface px-3 py-2 transition-colors hover:border-accent/60 hover:text-ink"
        >
          {source.name}
        </a>
      ))}
    </div>
  </div>
</footer>
